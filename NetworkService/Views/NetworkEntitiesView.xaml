<UserControl x:Class="NetworkService.Views.NetworkEntitiesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NetworkService.ViewModel"
             xmlns:beh="clr-namespace:NetworkService.Behaviors"
             Background="Transparent"
             beh:KeyboardBehavior.CtrlEnterCommand="{Binding AddCommand}"
             beh:KeyboardBehavior.EnterCommand="{Binding EnterCommand}"
             beh:KeyboardBehavior.DeleteCommand="{Binding DeleteCommand}"
             beh:KeyboardBehavior.EscapeCommand="{Binding EscapeCommand}">

    <UserControl.RenderTransform>
        <TranslateTransform/>
    </UserControl.RenderTransform>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.22"/>
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="12" To="0" Duration="0:0:0.24">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <UniformGrid Grid.Row="0" Rows="1" Columns="4" Margin="0,0,0,12">
                <Border Style="{StaticResource CardStyle}" Margin="0,0,6,0" Padding="14,11">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="8" Height="8" CornerRadius="4"
                                    Background="{StaticResource PrimaryBrush}"
                                    VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="UKUPNO ENTITETA" FontSize="9.5" FontWeight="Bold"
                                       Foreground="{StaticResource TextHintBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding KpiTotal}" FontSize="26" FontWeight="Bold"
                                   FontFamily="{StaticResource DisplayFont}"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="3,0,3,0" Padding="14,11">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="8" Height="8" CornerRadius="4"
                                    Background="{StaticResource SuccessBrush}"
                                    VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="VALIDNO" FontSize="9.5" FontWeight="Bold"
                                       Foreground="{StaticResource TextHintBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding KpiValid}" FontSize="26" FontWeight="Bold"
                                   FontFamily="{StaticResource DisplayFont}"
                                   Foreground="{StaticResource SuccessBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="3,0,3,0" Padding="14,11">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="8" Height="8" CornerRadius="4"
                                    Background="{StaticResource WarningBrush}"
                                    VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="VAN OPSEGA" FontSize="9.5" FontWeight="Bold"
                                       Foreground="{StaticResource TextHintBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding KpiOutOfRange}" FontSize="26" FontWeight="Bold"
                                   FontFamily="{StaticResource DisplayFont}"
                                   Foreground="{StaticResource WarningBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="6,0,0,0" Padding="14,11">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="8" Height="8" CornerRadius="4"
                                    Background="{StaticResource TextHintBrush}"
                                    VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <TextBlock Text="ČEKA PODATKE" FontSize="9.5" FontWeight="Bold"
                                       Foreground="{StaticResource TextHintBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding KpiWaiting}" FontSize="26" FontWeight="Bold"
                                   FontFamily="{StaticResource DisplayFont}"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="18,16" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="22" Height="22" CornerRadius="6"
                                    Background="{StaticResource PrimarySubtleBrush}" Margin="0,0,9,0">
                                <TextBlock Text="⛛" FontSize="11" Foreground="{StaticResource PrimaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="FILTER &amp; PRETRAGA" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="P2 · CG4" FontSize="10" Margin="10,0,0,0"
                                       Foreground="{StaticResource TextHintBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Poništi" Margin="0,0,8,0"
                                    Command="{Binding ResetFilterCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    ToolTip="Vrati prikaz na sve entitete (poništi filter/pretragu)"/>
                            <Button Content="Primeni filter"
                                    Command="{Binding ApplyFilterCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    ToolTip="Primeni filter na tabelu (kombinuje tip + ID uslov + stanje merenja)"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tip entiteta" Width="120"
                                   VerticalAlignment="Center" Margin="0,0,0,10"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" Width="240" HorizontalAlignment="Left"
                                  Margin="0,0,0,10"
                                  ItemsSource="{Binding TypeFilterOptions}"
                                  SelectedItem="{Binding SelectedTypeFilter}"
                                  ToolTip="Filtriraj po tipu entiteta"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="ID uslov" Width="120"
                                   VerticalAlignment="Center" Margin="0,0,0,10"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Style="{StaticResource SegmentedGroupStyle}" Margin="0,0,10,0">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="&lt;" Style="{StaticResource PillRadioStyle}"
                                                 IsChecked="{Binding FilterLess}" MinWidth="42"
                                                 ToolTip="ID manji od unesene vrednosti"/>
                                    <RadioButton Content="&gt;" Style="{StaticResource PillRadioStyle}"
                                                 IsChecked="{Binding FilterGreater}" MinWidth="42"
                                                 ToolTip="ID veći od unesene vrednosti"/>
                                    <RadioButton Content="=" Style="{StaticResource PillRadioStyle}"
                                                 IsChecked="{Binding FilterEqual}" MinWidth="42"
                                                 ToolTip="ID jednak unesenoj vrednosti"/>
                                </StackPanel>
                            </Border>
                            <TextBox Width="120" VerticalAlignment="Center"
                                     Text="{Binding IdFilterValue, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Unesite broj za poređenje ID-a"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Stanje merenja" Width="120"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                            <Border Style="{StaticResource SegmentedGroupStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <RadioButton Content="Van opsega" Style="{StaticResource PillRadioStyle}"
                                                 IsChecked="{Binding FilterOutOfRange}"
                                                 ToolTip="Samo entiteti čije je merenje van opsega 5–16 MP"/>
                                    <RadioButton Content="Unutar opsega" Style="{StaticResource PillRadioStyle}"
                                                 IsChecked="{Binding FilterInRange}"
                                                 ToolTip="Samo entiteti čije je merenje unutar opsega 5–16 MP"/>
                                    <RadioButton Content="Svi" Style="{StaticResource PillRadioStyle}"
                                                 IsChecked="{Binding FilterAllRange}"
                                                 ToolTip="Svi entiteti bez obzira na stanje merenja"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="opseg 5–16 MP" FontSize="11" Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextHintBrush}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                <DataGrid ItemsSource="{Binding FilteredVentili}"
                          SelectedItem="{Binding SelectedVentil}"
                          GridLinesVisibility="None">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="NAZIV" Binding="{Binding Name}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="TIP" Binding="{Binding Type.Name}" Width="180">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="POSL. MERENJE"
                                            Binding="{Binding MeasurementDisplay}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="12,0"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="STATUS" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="12,0">
                                        <Border CornerRadius="3" Padding="8,3" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#F0F4F8"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasMeasurement}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource SuccessLightBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsOutOfRange}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource WarningLightBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource WarningBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource TextHintBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasMeasurement}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsOutOfRange}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="0,0,0,10">
                <Button Content="Obriši označeni  [Del]"
                        Command="{Binding DeleteCommand}"
                        Style="{StaticResource DangerButtonStyle}"
                        ToolTip="Obriši označeni entitet iz tabele — prečica: Del (radi i bez fokusa na dugmetu)"/>
            </StackPanel>

            <Border Grid.Row="4" Style="{StaticResource CardStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="DODAJ NOVI ENTITET" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextHintBrush}" Margin="0,0,0,12"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="NAZIV" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextHintBrush}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Unesite naziv entiteta"/>
                            <TextBlock Text="{Binding NameError}" FontSize="11" Margin="0,3,0,0"
                                       Foreground="{StaticResource DangerBrush}"
                                       Visibility="{Binding HasNameError,
                                           Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="0,0,12,0">
                            <TextBlock Text="TIP" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextHintBrush}" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding EntityTypes}"
                                      SelectedItem="{Binding NewType}"
                                      DisplayMemberPath="Name"
                                      ToolTip="Odaberite tip entiteta"/>
                            <TextBlock Text="{Binding TypeError}" FontSize="11" Margin="0,3,0,0"
                                       Foreground="{StaticResource DangerBrush}"
                                       Visibility="{Binding HasTypeError,
                                           Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="ID (AUTO)" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextHintBrush}" Margin="0,0,0,5"/>
                            <TextBox Text="{Binding NextId, Mode=OneWay}" IsReadOnly="True"
                                     ToolTip="ID se dodeljuje automatski"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Content="Otkaži  [Esc]" Margin="0,0,8,0"
                                Command="{Binding CancelFormCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="Poništi unos forme i obriši unesene podatke (Esc)"/>
                        <Button Content="+ Dodaj  [Ctrl+Enter]"
                                Command="{Binding AddCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                ToolTip="Dodaj novi entitet u sistem (Ctrl+Enter)"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,0,0,0" Padding="16,16,16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="HISTORY" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextHintBrush}"/>
                    <TextBlock FontSize="10" Foreground="{StaticResource TextHintBrush}"
                               Margin="0,2,0,0">
                        <Run Text="Ctrl+Z"/>
                        <Run Text=" · "/>
                        <Run Text="Ctrl+⇧+Z sve"/>
                    </TextBlock>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding History}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1" Padding="0,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="3" CornerRadius="2"
                                                Background="{StaticResource PrimaryLightBrush}"
                                                VerticalAlignment="Stretch" Margin="0,2,0,2"/>
                                        <TextBlock Grid.Column="1" Margin="8,0,0,0"
                                                   Text="{Binding}" FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Grid.Row="1" Text="Još nema akcija."
                           FontSize="11" Foreground="{StaticResource TextHintBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding History.Count,
                               Converter={StaticResource ZeroCountToVisibilityConverter}}"/>

                <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0" Padding="0,8,0,0" Margin="0,4,0,0">
                    <TextBlock FontSize="10" Foreground="{StaticResource TextHintBrush}">
                        <Run Text="Ukupno entiteta: "/>
                        <Run Text="{Binding FilteredVentili.Count, Mode=OneWay}" FontWeight="SemiBold"
                             Foreground="{StaticResource TextSecondaryBrush}"/>
                    </TextBlock>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                Margin="16,0,16,16" CornerRadius="6" Padding="16,12"
                Background="#1A202C"
                Visibility="{Binding ToastVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="50">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="[OK]  " Foreground="{StaticResource SuccessLightBrush}"
                           FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ToastMessage}" Foreground="White"
                           FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="0" Grid.ColumnSpan="2" Panel.ZIndex="100"
              Visibility="{Binding ConfirmDeleteVisible, Converter={StaticResource BoolToVisibilityConverter}}"
              Background="#80000000">
            <Border Width="440" Background="White" CornerRadius="8" Padding="32"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Effect="{StaticResource ModalShadow}">
                <StackPanel>
                    <TextBlock Text="Potvrdi brisanje" FontSize="18" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,6">
                        <Run Text="Da li zaista zelis da obrises entitet:"/>
                    </TextBlock>
                    <TextBlock Text="{Binding PendingDeleteName}" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <TextBlock FontSize="12" Foreground="{StaticResource TextHintBrush}"
                               Margin="0,0,0,24">
                        <Run Text="MeteringSimulator ce biti automatski restartovan."/>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Otkazi" Margin="0,0,12,0"
                                Command="{Binding CancelDeleteCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                        <Button Content="Potvrdi  Enter"
                                Command="{Binding ConfirmDeleteCommand}"
                                Style="{StaticResource DangerButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
