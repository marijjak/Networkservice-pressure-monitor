<UserControl x:Class="NetworkService.Views.MeasurementGraphView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NetworkService.ViewModel"
             xmlns:beh="clr-namespace:NetworkService.Behaviors"
             Background="Transparent">

    <UserControl.RenderTransform>
        <TranslateTransform/>
    </UserControl.RenderTransform>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.22"/>
                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="12" To="0" Duration="0:0:0.24">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="16,12" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="240"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Entitet" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding Ventili}"
                              SelectedItem="{Binding SelectedVentil}"
                              ToolTip="Odaberite entitet za prikaz grafika merenja">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0}  (ID: {1})">
                                            <Binding Path="Name"/>
                                            <Binding Path="Id"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="20,16" Margin="0,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="BAR CHART PREMA VREMENU" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource TextHintBrush}"/>
                            <TextBlock Text="Poslednjih 5 merenja izabranog entiteta" FontSize="11"
                                       Foreground="{StaticResource TextHintBrush}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="1" CornerRadius="5" Padding="8,3" VerticalAlignment="Center"
                                Background="{StaticResource PrimarySubtleBrush}">
                            <TextBlock Text="G2" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryBrush}"/>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Pritisak (MP)" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock.LayoutTransform>
                                <RotateTransform Angle="-90"/>
                            </TextBlock.LayoutTransform>
                        </TextBlock>
                        <Canvas Grid.Column="1" x:Name="ChartCanvas"
                                beh:ChartBehavior.Measurements="{Binding Measurements}"
                                MinHeight="180"/>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="Vreme (HH:mm)" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0"
                                HorizontalAlignment="Center">
                        <Rectangle Width="13" Height="13" RadiusX="3" RadiusY="3"
                                   Fill="{StaticResource PrimaryBrush}" Margin="0,0,6,0"/>
                        <TextBlock Text="Validno (5–16 MP)" FontSize="11" Margin="0,0,20,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Rectangle Width="13" Height="13" RadiusX="3" RadiusY="3"
                                   Fill="{StaticResource WarningBrush}" Margin="0,0,6,0"/>
                        <TextBlock Text="Van opsega" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Grid.Row="2" Text="ZASTUPLJENOST TIPOVA ENTITETA (CG4)"
                       FontSize="10" FontWeight="Bold"
                       Foreground="{StaticResource TextHintBrush}" Margin="0,0,0,8"/>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="20,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Height="44" CornerRadius="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding KablovskiPercent,
                                    Converter={StaticResource PercentToGridLengthConverter}}"/>
                                <ColumnDefinition Width="{Binding DigitalniPercent,
                                    Converter={StaticResource PercentToGridLengthConverter}}"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource PrimaryGradient}"
                                    CornerRadius="5,0,0,5">
                                <TextBlock Text="{Binding KablovskiPercent, StringFormat='{}{0:0}%'}"
                                           Foreground="White" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="1" Background="#818CF8"
                                    CornerRadius="0,5,5,0">
                                <TextBlock Text="{Binding DigitalniPercent, StringFormat='{}{0:0}%'}"
                                           Foreground="#312E81" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="0%" FontSize="10"
                                   Foreground="{StaticResource TextHintBrush}"/>
                        <TextBlock Grid.Column="1" Text="25%" FontSize="10"
                                   Foreground="{StaticResource TextHintBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="50%" FontSize="10"
                                   Foreground="{StaticResource TextHintBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="75%" FontSize="10"
                                   Foreground="{StaticResource TextHintBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="100%" FontSize="10"
                                   Foreground="{StaticResource TextHintBrush}"/>
                    </Grid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,4">
                        <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2"
                                   Fill="{StaticResource PrimaryBrush}" Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding KablovskiLabel}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal">
                        <Rectangle Width="12" Height="12" RadiusX="2" RadiusY="2"
                                   Fill="#818CF8" Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DigitalniLabel}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,0,0,0" Padding="16,16,16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="HISTORY" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource TextHintBrush}"/>
                    <TextBlock FontSize="10" Foreground="{StaticResource TextHintBrush}"
                               Margin="0,2,0,0">
                        <Run Text="Ctrl+Z"/>
                        <Run Text=" · "/>
                        <Run Text="Ctrl+⇧+Z sve"/>
                    </TextBlock>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding History}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1" Padding="0,7">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="3" CornerRadius="2"
                                                Background="{StaticResource PrimaryLightBrush}"
                                                VerticalAlignment="Stretch" Margin="0,2,0,2"/>
                                        <TextBlock Grid.Column="1" Margin="8,0,0,0"
                                                   Text="{Binding}" FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Grid.Row="1" Text="Još nema akcija."
                           FontSize="11" Foreground="{StaticResource TextHintBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding History.Count,
                               Converter={StaticResource ZeroCountToVisibilityConverter}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
