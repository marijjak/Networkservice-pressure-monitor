<Window x:Class="NetworkService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NetworkService.ViewModel"
        xmlns:views="clr-namespace:NetworkService.Views"
        Title="NetworkService — Pressure Monitoring"
        Height="740" Width="1240" MinHeight="620" MinWidth="980"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:NetworkEntitiesViewModel}">
            <views:NetworkEntitiesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NetworkDisplayViewModel}">
            <views:NetworkDisplayView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:MeasurementGraphViewModel}">
            <views:MeasurementGraphView/>
        </DataTemplate>

        <Style x:Key="SegNavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#E2E8F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#F1F5F9"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource PrimaryLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShortcutChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#EEF2FF"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="D1" Modifiers="Alt"
                    Command="{Binding NavigateCommand}" CommandParameter="Entities"/>
        <KeyBinding Key="D2" Modifiers="Alt"
                    Command="{Binding NavigateCommand}" CommandParameter="Display"/>
        <KeyBinding Key="D3" Modifiers="Alt"
                    Command="{Binding NavigateCommand}" CommandParameter="Graph"/>
        <KeyBinding Key="Z" Modifiers="Ctrl"
                    Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl+Shift"
                    Command="{Binding UndoAllCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" Opacity="0.05" ShadowDepth="2"
                                  Direction="270" Color="#000000"/>
            </Border.Effect>
            <DockPanel Margin="20,0">

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left"
                            VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="9"
                            Background="{StaticResource BrandGradient}" Margin="0,0,12,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" Opacity="0.40" ShadowDepth="0"
                                              Color="#8B5CF6"/>
                        </Border.Effect>
                        <TextBlock Text="NS" Foreground="White" FontWeight="Bold"
                                   FontSize="13" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="NetworkService" FontSize="16" FontWeight="Bold"
                               FontFamily="{StaticResource DisplayFont}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="—" FontSize="15" Margin="8,0"
                               Foreground="{StaticResource TextHintBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock FontSize="14" VerticalAlignment="Center"
                               FontFamily="{StaticResource DisplayFont}"
                               Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Pressure Monitoring"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentViewName}" Value="Display">
                                        <Setter Property="Text" Value="Network Display"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding CurrentViewName}" Value="Graph">
                                        <Setter Property="Text" Value="Measurement Graph"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                            HorizontalAlignment="Right" VerticalAlignment="Center">

                    <Border Background="#F1F5F9" CornerRadius="9" Padding="3">
                        <StackPanel Orientation="Horizontal">

                            <Border CornerRadius="7">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentViewName}" Value="Entities">
                                                <Setter Property="Background" Value="{StaticResource BrandGradient}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Button Command="{Binding NavigateCommand}" CommandParameter="Entities"
                                        Style="{StaticResource SegNavButtonStyle}"
                                        ToolTip="Tabelarni prikaz entiteta (Alt+1)">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Entities">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentViewName}" Value="Entities">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource ShortcutChipStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentViewName}" Value="Entities">
                                                            <Setter Property="Background" Value="#6366F1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Alt+1" FontSize="9.5" FontFamily="Consolas">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CurrentViewName}" Value="Entities">
                                                                <Setter Property="Foreground" Value="#E0E7FF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Button>
                            </Border>

                            <Border CornerRadius="7" Margin="3,0,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentViewName}" Value="Display">
                                                <Setter Property="Background" Value="{StaticResource BrandGradient}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Button Command="{Binding NavigateCommand}" CommandParameter="Display"
                                        Style="{StaticResource SegNavButtonStyle}"
                                        ToolTip="Drag &amp; Drop mreža entiteta (Alt+2)">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Display">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentViewName}" Value="Display">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource ShortcutChipStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentViewName}" Value="Display">
                                                            <Setter Property="Background" Value="#6366F1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Alt+2" FontSize="9.5" FontFamily="Consolas">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CurrentViewName}" Value="Display">
                                                                <Setter Property="Foreground" Value="#E0E7FF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Button>
                            </Border>

                            <Border CornerRadius="7" Margin="3,0,0,0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentViewName}" Value="Graph">
                                                <Setter Property="Background" Value="{StaticResource BrandGradient}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Button Command="{Binding NavigateCommand}" CommandParameter="Graph"
                                        Style="{StaticResource SegNavButtonStyle}"
                                        ToolTip="Grafikon merenja (Alt+3)">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Graph">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentViewName}" Value="Graph">
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource ShortcutChipStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CurrentViewName}" Value="Graph">
                                                            <Setter Property="Background" Value="#6366F1"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="Alt+3" FontSize="9.5" FontFamily="Consolas">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CurrentViewName}" Value="Graph">
                                                                <Setter Property="Foreground" Value="#E0E7FF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                </Button>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Width="1" Background="{StaticResource BorderBrush}"
                            Margin="14,10" VerticalAlignment="Stretch"/>

                    <Button Command="{Binding UndoCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Poništi poslednju akciju (Ctrl+Z)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↩" FontSize="13" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Undo" VerticalAlignment="Center"/>
                            <Border Style="{StaticResource ShortcutChipStyle}" Background="#F1F5F9">
                                <TextBlock Text="Ctrl+Z" FontSize="9.5" FontFamily="Consolas"
                                           Foreground="{StaticResource TextHintBrush}"/>
                            </Border>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding UndoAllCommand}" Margin="6,0,0,0"
                            Style="{StaticResource ToolbarButtonStyle}"
                            ToolTip="Poništi sve izvršene akcije odjednom (Ctrl+Shift+Z)">
                        <Button.Visibility>
                            <Binding Path="CurrentViewName"
                                     Converter="{StaticResource ViewNameToUndoAllVisibilityConverter}"/>
                        </Button.Visibility>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⟲" FontSize="14" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Undo All" VerticalAlignment="Center"/>
                            <Border Style="{StaticResource ShortcutChipStyle}" Background="#F1F5F9">
                                <TextBlock Text="Ctrl+⇧+Z" FontSize="9.5" FontFamily="Consolas"
                                           Foreground="{StaticResource TextHintBrush}"/>
                            </Border>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#4F46E5" Offset="0"/>
                    <GradientStop Color="#8B5CF6" Offset="0.5"/>
                    <GradientStop Color="#A855F7" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid Grid.Row="2">
            <Rectangle Fill="{StaticResource BackgroundBrush}"/>
            <Rectangle Fill="{StaticResource DotGridBrush}" Opacity="0.7"/>
            <ContentControl Content="{Binding CurrentViewModel}"/>
        </Grid>
    </Grid>
</Window>
